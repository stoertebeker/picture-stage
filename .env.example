# ============================================================
# Picture-Stage – Environment Configuration
# ============================================================
# Copy this file to .env and adjust values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_NAME=Picture-Stage
APP_URL=http://localhost:8000
# Set to "production" on live instances. When ENV=production, the app refuses
# to start if SECRET_KEY or HMAC_SECRET_KEY are left at the CHANGE_ME default.
ENV=development
# REQUIRED in production: generate with
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME
DEBUG=false

# --- Database ---
DATABASE_URL=postgresql+asyncpg://picstage:picstage@db:5432/picstage
POSTGRES_USER=picstage
POSTGRES_PASSWORD=picstage
POSTGRES_DB=picstage

# --- Storage ---
# "local" or "s3"
STORAGE_BACKEND=local
# Local storage path (inside container)
UPLOAD_DIR=/app/uploads

# S3-compatible storage (only if STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=

# --- HMAC Signing (for image URLs) ---
# REQUIRED in production. 32+ byte key, generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
HMAC_SECRET_KEY=CHANGE_ME

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_STARTTLS=true

# --- Watermark ---
WATERMARK_TEXT=PREVIEW
WATERMARK_OPACITY=80
WATERMARK_FONT_SIZE_RATIO=0.05

# --- Rate Limiting ---
RATELIMIT_ENABLED=true



# --- Captcha (Altcha) ---
CAPTCHA_ENABLED=true
ALTCHA_SECRET_KEY=
