# ============================================================
# Picture-Stage – Environment Configuration
# ============================================================
# Copy this file to .env and adjust values.
# NEVER commit .env to version control.
# ============================================================

# --- Application ---
APP_NAME=Picture-Stage
# Public base URL of this instance — used to build gallery share links.
# REQUIRED in production: set this to your real public HTTPS domain (e.g.
# https://picture.example.com), NOT the container's internal address. Behind a
# TLS-terminating reverse proxy (Cloudflare/Caddy/nginx) the container only sees
# plain HTTP, so share links would otherwise leak the replayable token over
# http://. In production the scheme is additionally forced to https.
# This URL is ALSO the source of truth for cookie security (picture-stage-8ox):
# an https:// value enables the Secure flag on the session/CSRF/lang cookies and
# the HSTS header. Behind a proxy the container can't reliably derive this from
# the request, so set APP_URL to your real https:// domain in production.
APP_URL=http://localhost:8000
# Defaults to "production": the app refuses to start if SECRET_KEY or
# HMAC_SECRET_KEY are left at the CHANGE_ME default. Set ENVIRONMENT=development
# for local work / CI so default secrets are tolerated.
ENVIRONMENT=production
# REQUIRED in production: generate with
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME
DEBUG=false

# --- Database ---
DATABASE_URL=postgresql+asyncpg://picstage:picstage@db:5432/picstage
POSTGRES_USER=picstage
POSTGRES_PASSWORD=picstage
POSTGRES_DB=picstage

# --- Storage ---
# "local" or "s3"
STORAGE_BACKEND=local
# Local storage path (inside container)
UPLOAD_DIR=/app/uploads

# S3-compatible storage (only if STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=

# --- HMAC Signing (for image URLs) ---
# REQUIRED in production. 32+ byte key, generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
HMAC_SECRET_KEY=CHANGE_ME

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_STARTTLS=true
# Email ALL admins whenever a new user registers (operational alert, sent
# directly to every admin address — independent of per-user notification
# settings). Requires SMTP_HOST. Set to false to disable.
NOTIFY_ADMINS_ON_SIGNUP=true
# Send a verification email (with confirmation link) to the registrant on
# signup. Requires SMTP_HOST. Set to false to disable.
SEND_VERIFICATION_EMAIL_ENABLED=true
# Email the gallery owner (photographer) when a model completes their review
# (config-free, bypasses per-user notification settings). Requires SMTP_HOST.
# Set to false to disable.
NOTIFY_OWNER_ON_COMPLETION=true

# --- Watermark ---
WATERMARK_TEXT=PREVIEW
WATERMARK_OPACITY=80
WATERMARK_FONT_SIZE_RATIO=0.05

# --- Gallery Quota ---
# Maximum galleries a single user may own. Enforced only when creating a new
# gallery; never deletes or locks existing ones. 0 = unlimited.
MAX_GALLERIES_PER_USER=5

# --- Upload Limits ---
# Enforced at upload time, so changing these and restarting applies to all
# uploads including existing galleries. 0 disables the respective limit.
# Per-file size cap in MB (primary guard against OOM).
MAX_UPLOAD_FILE_MB=50
# Maximum number of files accepted in a single upload request.
MAX_FILES_PER_UPLOAD=500
# Global request-body size cap in MB (defense-in-depth). An over-sized body is
# rejected with 413 at the ASGI layer before it is fully spooled to disk. The
# default sits well above any legitimate multi-upload request. Set a matching
# reverse-proxy limit (Caddy request_body / Cloudflare) as the outer layer too.
# 0 = no app-level limit.
MAX_REQUEST_BODY_MB=1024
# Decompression-bomb guard: max decoded pixels before Pillow rejects an image
# (DecompressionBombError) instead of allocating huge amounts of RAM. Applies to
# every image-decode path. 100 MP sits far above real photos. 0 = no cap.
MAX_IMAGE_PIXELS=100000000

# --- Rate Limiting ---
RATELIMIT_ENABLED=true



# --- Captcha (Altcha) ---
CAPTCHA_ENABLED=true
ALTCHA_SECRET_KEY=
